---
const navItems = [
  { label: "リトルリーグとは", href: "/about" },
  { label: "選手紹介",         href: "/players" },
  { label: "試合結果",         href: "/results" },
  { label: "グラウンド",       href: "/ground" },
  { label: "Q&A",             href: "/qa" },
  { label: "アルバム",         href: "/album" },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header__inner">
    <a href="/" class="header__logo">横浜東リトルリーグ</a>

    <!-- PC nav -->
    <nav class="header__nav">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`header__nav-item ${currentPath.startsWith(item.href) ? "is-active" : ""}`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a href="/contact" class="header__cta">体験参加のお問い合わせ</a>

    <!-- ハンバーガー -->
    <button class="header__hamburger" aria-label="メニューを開く" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- モバイルドロワー -->
<div class="drawer" aria-hidden="true">
  <div class="drawer__overlay"></div>
  <nav class="drawer__nav">
    {navItems.map(item => (
      <a href={item.href} class="drawer__item">{item.label}</a>
    ))}
    <a href="/contact" class="drawer__cta">体験参加のお問い合わせ</a>
  </nav>
</div>

<style lang="scss">
@use 'var' as *;

.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: $navy;
  border-bottom: 1px solid $border;

  &__inner {
    display: flex;
    align-items: center;
    gap: 2.4rem;
    height: 6.0rem;
    padding: 0 $margin-mobile;

    @include pc {
      height: 7.2rem;
      padding: 0 $margin-pc;
    }
  }

  &__logo {
    font-size: $fs-md; // 1.5rem = 15px
    font-weight: 700;
    color: $text-primary;
    white-space: nowrap;

    @include pc { font-size: $fs-lg; } // 1.8rem = 18px
  }

  &__nav {
    display: none;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;

    @include pc { display: flex; }
  }

  &__nav-item {
    font-size: $fs-base; // 1.3rem = 13px
    font-weight: 700;
    color: $text-secondary;
    padding: 0.6rem 1.2rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;

    &:hover, &.is-active {
      color: $text-primary;
      background: rgba(255,255,255,0.06);
    }
  }

  &__cta {
    display: none;
    font-size: $fs-sm; // 1.1rem = 11px
    font-weight: 700;
    background: $orange;
    color: $white;
    padding: 0.8rem 1.4rem;
    border-radius: 4px;
    white-space: nowrap;
    transition: opacity 0.2s;
    margin-left: 0.8rem;

    &:hover { opacity: 0.85; }

    @include pc { display: block; }
  }

  &__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
    width: 3.2rem;
    height: 3.2rem;
    background: none;
    border: none;
    cursor: pointer;
    margin-left: auto;
    padding: 0.4rem;

    @include pc { display: none; }

    span {
      display: block;
      width: 2.2rem;
      height: 2px;
      background: $text-primary;
      border-radius: 1px;
      transition: transform 0.25s, opacity 0.25s;
    }

    &.is-open {
      span:nth-child(1) { transform: translateY(0.8rem) rotate(45deg); }
      span:nth-child(2) { opacity: 0; }
      span:nth-child(3) { transform: translateY(-0.8rem) rotate(-45deg); }
    }
  }
}

// ドロワー
.drawer {
  position: fixed;
  inset: 0;
  z-index: 99;
  pointer-events: none;

  &.is-open {
    pointer-events: auto;

    .drawer__overlay { opacity: 1; }
    .drawer__nav { transform: translateX(0); }
  }

  &__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    opacity: 0;
    transition: opacity 0.3s;
  }

  &__nav {
    position: absolute;
    top: 0;
    right: 0;
    width: min(28.0rem, 80vw);
    height: 100%;
    background: $navy-mid;
    padding: 8.0rem 2.4rem 3.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  &__item {
    font-size: $fs-md; // 1.5rem = 15px
    font-weight: 700;
    color: $text-secondary;
    padding: 1.2rem 0.8rem;
    border-bottom: 1px solid $border;

    &:hover { color: $text-primary; }
  }

  &__cta {
    margin-top: 2.4rem;
    font-size: $fs-base; // 1.3rem = 13px
    font-weight: 700;
    background: $orange;
    color: $white;
    padding: 1.4rem 2.0rem;
    border-radius: 6px;
    text-align: center;
  }
}
</style>

<script>
const hamburger = document.querySelector('.header__hamburger');
const drawer = document.querySelector('.drawer');
const overlay = document.querySelector('.drawer__overlay');

function toggleDrawer(open: boolean) {
  hamburger?.setAttribute('aria-expanded', String(open));
  hamburger?.classList.toggle('is-open', open);
  drawer?.classList.toggle('is-open', open);
  drawer?.setAttribute('aria-hidden', String(!open));
  document.body.style.overflow = open ? 'hidden' : '';
}

hamburger?.addEventListener('click', () => {
  const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
  toggleDrawer(!isOpen);
});

overlay?.addEventListener('click', () => toggleDrawer(false));
</script>
