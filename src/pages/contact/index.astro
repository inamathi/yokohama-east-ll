---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="お問い合わせ | 横浜東リトルリーグ">

  <div class="page-title-bar">
    <div class="container">
      <h1>お問い合わせ</h1>
      <p class="sub">CONTACT</p>
    </div>
  </div>

  <div class="container contact-wrap">
    <div class="contact-grid">
      <div class="contact-form">
        <div class="field-group">
          <label class="field-label">お名前 <span class="required">必須</span></label>
          <input type="text" class="field-input" placeholder="例：山田 太郎" id="name" />
        </div>
        <div class="field-group">
          <label class="field-label">お子様の学年 <span class="required">必須</span></label>
          <input type="text" class="field-input" placeholder="例：小学2年生" id="grade" />
        </div>
        <div class="field-group">
          <label class="field-label">メールアドレス <span class="required">必須</span></label>
          <input type="email" class="field-input" placeholder="例：example@email.com" id="email" />
        </div>
        <div class="field-group">
          <label class="field-label">メールアドレス（確認用） <span class="required">必須</span></label>
          <input type="email" class="field-input" placeholder="もう一度入力してください" id="emailConfirm" />
        </div>
        <div class="field-group">
          <label class="field-label">お住まいの地域 <span class="required">必須</span></label>
          <input type="text" class="field-input" placeholder="例：横浜市港北区" id="area" />
        </div>
        <div class="field-group">
          <label class="field-label">メッセージ <span class="required">必須</span></label>
          <textarea class="field-input field-textarea" placeholder="お問い合わせ内容をご記入ください" id="message" rows="5"></textarea>
        </div>
        <div class="tel-section">
          <div class="field-group">
            <label class="field-label">携帯電話 <span class="optional">任意</span></label>
            <p class="field-note">電話連絡をご希望の方はご入力ください</p>
            <input type="tel" class="field-input" placeholder="例：090-0000-0000" id="tel" />
          </div>
        </div>
        <div class="privacy-accordion" id="privacyAccordion">
          <button class="privacy-accordion__toggle" aria-expanded="false">
            個人情報の取り扱いについて
            <span class="privacy-accordion__icon">▼</span>
          </button>
          <div class="privacy-accordion__body" hidden>
            <p>ご入力いただいた個人情報は、お問い合わせへの返信および体験参加・入団に関するご連絡のみに使用します。第三者への提供や、目的外の利用は一切行いません。</p>
          </div>
        </div>
        <button class="btn btn--primary submit-btn" id="submitBtn">送信する</button>
        <div class="form-message" id="formMessage"></div>
      </div>

      <div class="contact-info">
        <h2 class="contact-info__title">体験参加について</h2>
        <p class="contact-info__text">
          体験参加は無料です。道具も不要。<br />
          まずは見学だけでもお気軽にどうぞ。<br /><br />
          通常2営業日以内にご返信いたします。
        </p>
      </div>
    </div>
  </div>

</Layout>

<style lang="scss">
@use 'var' as *;

.contact-wrap {
  padding-top: 4.0rem;
  padding-bottom: 6.0rem;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4.0rem;

  @include pc { grid-template-columns: 1fr 32rem; align-items: start; }
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  margin-bottom: 2.0rem;
}

.field-label {
  font-size: $fs-base; // 1.3rem = 13px
  font-weight: 700;
  color: $text-secondary;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}

.required {
  font-size: 0.9rem; // 9px
  background: #dc3c3c;
  color: $white;
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
}

.optional {
  font-size: $fs-xs; // 1.0rem = 10px
  color: $text-muted;
}

.field-note {
  font-size: $fs-base; // 1.3rem = 13px
  color: $text-muted;
  margin-top: -0.4rem;
}

.field-input {
  background: #16243f;
  border: 1px solid $border;
  border-radius: 6px;
  padding: 1.2rem;
  font-size: $fs-md; // 1.5rem = 15px
  font-family: $font-body;
  color: $text-primary;
  width: 100%;
  transition: border-color 0.2s;

  &::placeholder { color: $text-muted; }
  &:focus { outline: none; border-color: $cyan; }
}

.field-textarea { resize: vertical; min-height: 12rem; }

.tel-section {
  background: $navy-mid;
  border-radius: 8px;
  padding: 1.6rem;
  margin-bottom: 2.0rem;

  .field-group { margin-bottom: 0; }
}

.privacy-accordion {
  margin-bottom: 2.4rem;

  &__toggle {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: $navy-mid;
    border: none;
    border-radius: 6px;
    padding: 1.2rem 1.6rem;
    font-size: $fs-base; // 1.3rem = 13px
    font-weight: 700;
    color: $text-secondary;
    cursor: pointer;
    text-align: left;

    &:hover { color: $text-primary; }
  }

  &__icon { font-size: 0.9rem; color: $text-muted; transition: transform 0.2s; }
  &[data-open] &__icon { transform: rotate(180deg); }

  &__body {
    background: $navy-mid;
    border-radius: 0 0 6px 6px;
    padding: 1.2rem 1.6rem;
    font-size: $fs-base; // 1.3rem = 13px
    color: $text-secondary;
    line-height: 1.75;
    margin-top: 0.2rem;
  }
}

.submit-btn { width: 100%; padding: 1.6rem; font-size: $fs-lg; }

.form-message {
  margin-top: 1.2rem;
  font-size: $fs-base; // 1.3rem = 13px
  text-align: center;

  &.success { color: $cyan; }
  &.error   { color: #ff6b6b; }
}

.contact-info {
  background: $navy-mid;
  border-radius: 8px;
  padding: 2.4rem;

  &__title { font-size: $fs-lg; font-weight: 700; margin-bottom: 1.6rem; }
  &__text  { font-size: $fs-base; color: $text-secondary; line-height: 1.8; }
}
</style>

<script>
const GAS_URL = "https://script.google.com/macros/s/AKfycbzk5a9ycCom5ctNIl02Eu5lvHNi8kMbiMZB-QU_VMXYQE7of6b5eVaF6cF82fggJWPY/exec";

const accordion = document.getElementById('privacyAccordion');
const toggle = accordion?.querySelector('.privacy-accordion__toggle');
const body = accordion?.querySelector('.privacy-accordion__body');

toggle?.addEventListener('click', () => {
  const isOpen = toggle.getAttribute('aria-expanded') === 'true';
  toggle.setAttribute('aria-expanded', String(!isOpen));
  if (isOpen) { body?.setAttribute('hidden', ''); accordion?.removeAttribute('data-open'); }
  else        { body?.removeAttribute('hidden');  accordion?.setAttribute('data-open', ''); }
});

const submitBtn = document.getElementById('submitBtn');
const formMessage = document.getElementById('formMessage');

submitBtn?.addEventListener('click', async () => {
  const name         = document.getElementById('name')?.value.trim();
  const grade        = document.getElementById('grade')?.value.trim();
  const email        = document.getElementById('email')?.value.trim();
  const emailConfirm = document.getElementById('emailConfirm')?.value.trim();
  const area         = document.getElementById('area')?.value.trim();
  const message      = document.getElementById('message')?.value.trim();
  const tel          = document.getElementById('tel')?.value.trim();

  if (!name || !grade || !email || !area || !message) {
    formMessage.textContent = '必須項目を入力してください。';
    formMessage.className = 'form-message error';
    return;
  }
  if (email !== emailConfirm) {
    formMessage.textContent = 'メールアドレスが一致しません。';
    formMessage.className = 'form-message error';
    return;
  }

  submitBtn.textContent = '送信中…';
  submitBtn.setAttribute('disabled', '');

  try {
    const params = new URLSearchParams({ action: 'submit', name, grade, email, area, message, tel });
    await fetch(`${GAS_URL}?${params}`);
    formMessage.textContent = '送信が完了しました。2営業日以内にご返信いたします。';
    formMessage.className = 'form-message success';
    submitBtn.textContent = '送信完了';
  } catch {
    formMessage.textContent = '送信に失敗しました。しばらく経ってから再度お試しください。';
    formMessage.className = 'form-message error';
    submitBtn.textContent = '送信する';
    submitBtn.removeAttribute('disabled');
  }
});
</script>
