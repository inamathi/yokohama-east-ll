---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="お問い合わせ">
  <section class="page-hero">
    <p class="hero-label">Contact</p>
    <h1>お問い合わせ</h1>
    <p class="hero-sub">入団のご相談・見学のお申し込みはお気軽にどうぞ</p>
  </section>

  <section class="section">
    <div class="contact-grid">
      <!-- 左: 情報 -->
      <div class="contact-info">
        <h2>横浜東リトルリーグ</h2>
        <p>
          神奈川東部を拠点に活動しています。<br
          />小学生であれば経験・未経験問わず大歓迎です。
        </p>

        <div class="appeal-cards">
          <div class="appeal-card">
            <div class="appeal-icon">⚾</div>
            <h3>初心者大歓迎‼️</h3>
            <p>
              野球が初めてでも大丈夫。基礎的な動きから丁寧に指導しますので、安心してご参加ください。
            </p>
          </div>
          <div class="appeal-card highlight">
            <div class="appeal-icon">🔥</div>
            <h3>経験者・硬式野球への挑戦を考える選手へ</h3>
            <p>
              中学から硬式野球へのチャレンジを考えている選手に特におすすめ。リトルリーグでの硬式球でのプレイ経験は、硬式野球への移行期に非常に有効です。
            </p>
          </div>
        </div>

        <div class="info-list">
          <div class="info-item">
            <span class="info-label">活動エリア</span>
            <span>神奈川東部（横浜市・川崎市）</span>
          </div>
          <div class="info-item">
            <span class="info-label">練習日</span>
            <span>土・日・祝日</span>
          </div>
          <div class="info-item">
            <span class="info-label">対象</span>
            <span>小学1年生〜6年生</span>
          </div>
          <div class="info-item">
            <span class="info-label">体験練習</span>
            <span>随時受付（要事前連絡）</span>
          </div>
        </div>
      </div>
      <!-- 右: フォーム -->
      <div class="contact-form-wrap">
        <form id="contactForm">
          <div class="form-group">
            <label>お名前</label>
            <input type="text" name="name" placeholder="山田 太郎" required />
          </div>
          <div class="form-group">
            <label>メールアドレス</label>
            <input
              type="email"
              name="email"
              placeholder="example@email.com"
              required
            />
          </div>
          <div class="form-group">
            <label>お住まいの地域</label>
            <select name="area">
              <option value="">選択してください</option>
              <optgroup label="横浜市">
                <option>横浜市鶴見区</option>
                <option>横浜市神奈川区</option>
                <option>横浜市西区</option>
                <option>横浜市中区</option>
                <option>横浜市南区</option>
                <option>横浜市保土ケ谷区</option>
                <option>横浜市磯子区</option>
                <option>横浜市金沢区</option>
                <option>横浜市港北区</option>
                <option>横浜市戸塚区</option>
                <option>横浜市港南区</option>
                <option>横浜市旭区</option>
                <option>横浜市緑区</option>
                <option>横浜市瀬谷区</option>
                <option>横浜市栄区</option>
                <option>横浜市泉区</option>
                <option>横浜市青葉区</option>
                <option>横浜市都筑区</option>
              </optgroup>
              <optgroup label="川崎市">
                <option>川崎市川崎区</option>
                <option>川崎市幸区</option>
                <option>川崎市中原区</option>
                <option>川崎市高津区</option>
                <option>川崎市多摩区</option>
                <option>川崎市宮前区</option>
                <option>川崎市麻生区</option>
              </optgroup>
              <optgroup label="その他">
                <option>横須賀市</option>
                <option>鎌倉市</option>
                <option>逗子市</option>
                <option>三浦市</option>
                <option>その他神奈川県内</option>
                <option>神奈川県外</option>
              </optgroup>
            </select>
          </div>
          <div class="form-group">
            <label>お子様の学年</label>
            <select name="grade">
              <option value="">選択してください</option>
              <option>小学1年生</option>
              <option>小学2年生</option>
              <option>小学3年生</option>
              <option>小学4年生</option>
              <option>小学5年生</option>
              <option>小学6年生</option>
              <option>未就学</option>
              <option>その他</option>
            </select>
          </div>
          <div class="form-group">
            <label>お問い合わせ種別</label>
            <select name="subject" required>
              <option value="">選択してください</option>
              <option>入団・見学について</option>
              <option>体験練習の申し込み</option>
              <option>その他</option>
            </select>
          </div>
          <div class="form-group">
            <label>メッセージ</label>
            <textarea
              name="message"
              rows="4"
              placeholder="ご質問・ご要望をお気軽にどうぞ"></textarea>
          </div>

          <button type="submit" class="btn btn-primary">送信する</button>
          <p id="contact-msg"></p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  @import "@/styles/global.scss";

  $cyan: #4b99d2;

  .page-hero {
    background: linear-gradient(135deg, $navy 0%, #0d2244 100%);
    border-bottom: 3px solid $orange;
    padding: 3rem 1.5rem;

    .hero-label {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: $orange;
      margin-bottom: 0.5rem;
    }

    h1 {
      font-family: $font-display;
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .hero-sub {
      font-size: 0.9rem;
      color: #aac0d5;
    }
  }

  .section {
    padding: 3rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  // 左側情報
  .contact-info {
    h2 {
      font-family: $font-display;
      font-size: 1.3rem;
      margin-bottom: 0.75rem;
    }

    p {
      font-size: 0.9rem;
      color: #aac0d5;
      margin-bottom: 1.5rem;
      line-height: 1.8;
    }
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .info-item {
    display: flex;
    gap: 1rem;
    font-size: 0.88rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .info-label {
    font-weight: 700;
    color: rgba(255, 255, 255, 0.5);
    white-space: nowrap;
    min-width: 80px;
  }

  // フォーム
  .contact-form-wrap {
    background: #102040;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1rem;

    label {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: rgba(255, 255, 255, 0.5);
    }

    input,
    select,
    textarea {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      color: $white;
      font-size: 0.9rem;
      font-family: $font-body;
      padding: 0.6rem 0.75rem;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;

      &:focus {
        border-color: $cyan;
      }
    }

    select option {
      background: $navy;
    }
  }

  .btn {
    font-family: $font-display;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.75rem 1.75rem;
    border-radius: 3px;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    width: 100%;
    margin-top: 0.5rem;

    &-primary {
      background: $cyan;
      color: $white;

      &:hover {
        background: lighten($cyan, 10%);
        transform: translateY(-2px);
      }
    }
  }

  #contact-msg {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    text-align: center;
    min-height: 1.5rem;
  }
</style>

<script>
  document
    .getElementById("contactForm")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const msg = document.getElementById("contact-msg")!;
      msg.textContent = "送信しました！後ほどご連絡いたします。";
      msg.style.color = "#4B99D2";
      (e.target as HTMLFormElement).reset();
    });
</script>
