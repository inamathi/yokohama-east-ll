---
import Layout from '@/layouts/Layout.astro';

const archives = [
  {
    season: '2024-25',
    results: [
      { date: '2025-03-10', team: 'メジャー', type: '公式戦', tournament: '春季大会', round: '1回戦', venue: '横浜スタジアム補助', opponent: '港南リトルリーグ', our: 5, opp: 2, note: '' },
      { date: '2025-02-15', team: 'ジュニア', type: 'OPG',    tournament: '',         round: '',      venue: '保土ヶ谷球場',       opponent: '磯子リトルリーグ', our: 3, opp: 3, note: '' },
      { date: '2025-01-20', team: 'マイナー', type: '公式戦', tournament: '冬季大会', round: '2回戦', venue: '横浜東公園',         opponent: '金沢リトルリーグ', our: 1, opp: 4, note: '' },
    ],
  },
  {
    season: '2023-24',
    results: [
      { date: '2024-08-10', team: 'メジャー', type: '公式戦', tournament: '夏季大会', round: '決勝',  venue: '横浜スタジアム補助', opponent: '鶴見リトルリーグ', our: 8, opp: 1, note: '' },
      { date: '2024-07-05', team: 'マイナー', type: 'OPG',    tournament: '',         round: '',      venue: '根岸森林公園',       opponent: '旭リトルリーグ',   our: 2, opp: 6, note: '' },
    ],
  },
];

const teamOrder = ['メジャー', 'マイナー', 'ジュニア'] as const;
type TeamName = typeof teamOrder[number];
---

<Layout title="過去の試合結果">

  <section class="page-hero">
    <p class="hero-label">Archive</p>
    <h1>過去の試合結果</h1>
  </section>

  <section class="section">

    <div class="back-link">
      <a href="/results">← 今シーズンの結果に戻る</a>
    </div>

    {archives.map(archive => {
      const sid = archive.season.replace('-', '_');

      return (
        <details class="archive-block">
          <summary class="archive-summary">
            <span class="archive-season">{archive.season}</span>
            <span class="archive-count">{archive.results.length}件</span>
            <span class="archive-arrow">▶</span>
          </summary>

          <div class="archive-content">

            <!-- タブバー -->
            <div class="tab-bar">
              <button class="tab-btn active" data-sid={sid} data-tab={`${sid}__一覧`}>一覧</button>
              {teamOrder.map(team => (
                <button class="tab-btn" data-sid={sid} data-tab={`${sid}__${team}`}>
                  {team}
                </button>
              ))}
            </div>

            <!-- 一覧タブ -->
            <div class="tab-pane active" data-sid={sid} data-pane={`${sid}__一覧`}>
              {(['公式戦', 'OPG'] as const).map(type => {
                const rows = archive.results.filter(r => r.type === type);
                return (
                  <div>
                    <h2 class="table-heading">{type === 'OPG' ? 'オープン戦（OPG）' : '公式戦'}</h2>
                    <div class="table-wrap">
                      <table>
                        <thead>
                          <tr>
                            <th>日付</th>
                            <th>カテゴリ</th>
                            {type === '公式戦' && <th>大会名</th>}
                            {type === '公式戦' && <th>回戦</th>}
                            <th>球場</th>
                            <th>対戦相手</th>
                            <th>スコア</th>
                            <th>結果</th>
                            <th>備考</th>
                          </tr>
                        </thead>
                        <tbody>
                          {rows.length === 0 ? (
                            <tr><td colspan={type === '公式戦' ? 9 : 7} class="empty">データなし</td></tr>
                          ) : rows.map(r => {
                            const result = r.our > r.opp ? 'win' : r.our < r.opp ? 'lose' : 'draw';
                            const label  = result === 'win' ? '○' : result === 'lose' ? '●' : '△';
                            return (
                              <tr>
                                <td>{r.date}</td>
                                <td><span class={`team-badge team-${r.team}`}>{r.team}</span></td>
                                {type === '公式戦' && <td>{r.tournament}</td>}
                                {type === '公式戦' && <td>{r.round}</td>}
                                <td>{r.venue}</td>
                                <td>{r.opponent}</td>
                                <td><strong>{r.our} - {r.opp}</strong></td>
                                <td><span class={`badge badge-${result}`}>{label}</span></td>
                                <td class="note">{r.note}</td>
                              </tr>
                            );
                          })}
                        </tbody>
                      </table>
                    </div>
                  </div>
                );
              })}
            </div>

            <!-- チーム別タブ -->
            {teamOrder.map(team => {
              const filtered = archive.results.filter(r => r.team === team);
              const official = filtered.filter(r => r.type === '公式戦');
              const opg      = filtered.filter(r => r.type === 'OPG');

              return (
                <div class="tab-pane" data-sid={sid} data-pane={`${sid}__${team}`}>

                  <h2 class="table-heading">公式戦</h2>
                  <div class="table-wrap">
                    <table>
                      <thead>
                        <tr>
                          <th>日付</th>
                          <th>大会名</th>
                          <th>回戦</th>
                          <th>球場</th>
                          <th>対戦相手</th>
                          <th>スコア</th>
                          <th>結果</th>
                          <th>備考</th>
                        </tr>
                      </thead>
                      <tbody>
                        {official.length === 0 ? (
                          <tr><td colspan={8} class="empty">データなし</td></tr>
                        ) : official.map(r => {
                          const result = r.our > r.opp ? 'win' : r.our < r.opp ? 'lose' : 'draw';
                          const label  = result === 'win' ? '○' : result === 'lose' ? '●' : '△';
                          return (
                            <tr>
                              <td>{r.date}</td>
                              <td>{r.tournament}</td>
                              <td>{r.round}</td>
                              <td>{r.venue}</td>
                              <td>{r.opponent}</td>
                              <td><strong>{r.our} - {r.opp}</strong></td>
                              <td><span class={`badge badge-${result}`}>{label}</span></td>
                              <td class="note">{r.note}</td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>

                  <h2 class="table-heading" style="margin-top:2rem;">オープン戦（OPG）</h2>
                  <div class="table-wrap">
                    <table>
                      <thead>
                        <tr>
                          <th>日付</th>
                          <th>球場</th>
                          <th>対戦相手</th>
                          <th>スコア</th>
                          <th>結果</th>
                          <th>備考</th>
                        </tr>
                      </thead>
                      <tbody>
                        {opg.length === 0 ? (
                          <tr><td colspan={6} class="empty">データなし</td></tr>
                        ) : opg.map(r => {
                          const result = r.our > r.opp ? 'win' : r.our < r.opp ? 'lose' : 'draw';
                          const label  = result === 'win' ? '○' : result === 'lose' ? '●' : '△';
                          return (
                            <tr>
                              <td>{r.date}</td>
                              <td>{r.venue}</td>
                              <td>{r.opponent}</td>
                              <td><strong>{r.our} - {r.opp}</strong></td>
                              <td><span class={`badge badge-${result}`}>{label}</span></td>
                              <td class="note">{r.note}</td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>

                </div>
              );
            })}

          </div>
        </details>
      );
    })}

  </section>

</Layout>

<style lang="scss">
@import '@/styles/global.scss';

.page-hero {
  background: linear-gradient(135deg, $navy 0%, #0d2244 100%);
  border-bottom: 3px solid $orange;
  padding: 3rem 1.5rem;

  .hero-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: $orange;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-family: $font-display;
    font-size: 2.5rem;
    font-weight: 700;
  }
}

.section {
  padding: 3rem 1.5rem;
  max-width: 1100px;
  margin: 0 auto;
}

.back-link {
  margin-bottom: 2rem;

  a {
    font-size: 0.85rem;
    color: $gray;
    transition: color 0.2s;
    &:hover { color: $white; }
  }
}

.archive-block {
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 8px;
  margin-bottom: 1rem;
  overflow: hidden;

  &[open] .archive-arrow { transform: rotate(90deg); }
}

.archive-summary {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  background: #102040;
  cursor: pointer;
  list-style: none;
  transition: background 0.2s;

  &:hover { background: #0d2244; }
  &::-webkit-details-marker { display: none; }
}

.archive-season {
  font-family: $font-display;
  font-size: 1.1rem;
  font-weight: 700;
}

.archive-count {
  font-size: 0.8rem;
  color: $gray;
}

.archive-arrow {
  margin-left: auto;
  font-size: 0.7rem;
  color: $gray;
  transition: transform 0.2s;
}

.archive-content {
  padding: 1.5rem;
}

.tab-bar {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
  border-bottom: 2px solid rgba(255,255,255,.08);
  padding-bottom: 0.5rem;
  flex-wrap: wrap;
}

.tab-btn {
  font-family: $font-display;
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  padding: 0.45rem 1rem;
  background: transparent;
  color: $gray;
  border: 1px solid rgba(255,255,255,.1);
  cursor: pointer;
  border-radius: 3px;
  transition: all 0.2s;

  &.active {
    background: $white;
    color: $navy;
    border-color: $white;
  }

  &:hover:not(.active) {
    border-color: rgba(255,255,255,.3);
    color: $white;
  }
}

.tab-pane {
  display: none;
  &.active { display: block; }
}

.table-heading {
  font-family: $font-display;
  font-size: 0.9rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: $white;
  margin-bottom: 0.75rem;
  padding-left: 0.75rem;
  border-left: 3px solid rgba(255,255,255,.2);
}

.table-wrap {
  overflow-x: auto;
  margin-bottom: 0.5rem;

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  th {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255,255,255,.5);
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,.1);
    text-align: left;
    white-space: nowrap;
  }

  td {
    padding: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,.05);
    color: #ccdde6;
    white-space: nowrap;
  }

  tr:hover td { background: rgba(255,255,255,.03); }

  .empty {
    text-align: center;
    color: $gray;
    padding: 1.5rem;
  }

  .note {
    color: $gray;
    font-size: 0.82rem;
    white-space: normal;
    min-width: 120px;
  }
}

.team-badge {
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.15rem 0.6rem;
  border-radius: 2px;

  &.team-メジャー { background: rgba(59,26,189,.3);  color: #a090ef; }
  &.team-ジュニア { background: rgba(75,153,210,.2); color: #4B99D2; }
  &.team-マイナー { background: rgba(255,144,33,.2); color: #ff9021; }
}

.badge {
  font-size: 1rem;
  font-weight: 700;

  &-win  { color: $white; }
  &-lose { color: $white; }
  &-draw { color: $white; }
}
</style>

<script>
  // アコーディオン：OPENをひとつだけに制限
  document.querySelectorAll<HTMLElement>('details.archive-block').forEach(detail => {
    detail.addEventListener('toggle', () => {
      if (detail.open) {
        document.querySelectorAll<HTMLElement>('details.archive-block').forEach(other => {
          if (other !== detail) other.removeAttribute('open');
        });
      }
    });
  });

  // タブ切り替え
  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const sid = btn.dataset.sid!;

      document.querySelectorAll<HTMLButtonElement>(`.tab-btn[data-sid="${sid}"]`)
        .forEach(b => b.classList.remove('active'));
      document.querySelectorAll<HTMLElement>(`.tab-pane[data-sid="${sid}"]`)
        .forEach(p => p.classList.remove('active'));

      btn.classList.add('active');
      const pane = document.querySelector<HTMLElement>(
        `.tab-pane[data-pane="${btn.dataset.tab}"]`
      );
      if (pane) pane.classList.add('active');
    });
  });
</script>