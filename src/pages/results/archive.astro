---
import Layout from '@/layouts/Layout.astro';

const GAS_URL = "https://script.google.com/macros/s/AKfycbzk5a9ycCom5ctNIl02Eu5lvHNi8kMbiMZB-QU_VMXYQE7of6b5eVaF6cF82fggJWPY/exec";
---

<Layout title="試合結果アーカイブ | 横浜東リトルリーグ">

  <div class="page-title-bar">
    <div class="container">
      <h1>試合結果アーカイブ</h1>
      <p class="sub">RESULTS ARCHIVE</p>
    </div>
  </div>

  <div class="container archive-wrap">
    <div class="archive-list" id="archiveList">
      <div class="loading">読み込み中…</div>
    </div>
  </div>

</Layout>

<style lang="scss">
@use 'var' as *;

.archive-wrap {
  padding-top: 32px;
  padding-bottom: 48px;
}

.loading {
  color: $text-muted;
  font-size: 13px;
  text-align: center;
  padding: 40px 0;
}

.season-block {
  margin-bottom: 40px;

  &__title {
    font-size: 18px;
    font-weight: 700;
    color: $text-primary;
    padding: 8px 0;
    border-bottom: 1px solid $border;
    margin-bottom: 12px;
  }
}

.result-card {
  background: $navy-mid;
  border-radius: 8px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  margin-bottom: 8px;

  &__left {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-start;
  }

  &__date { font-size: 10px; color: $text-muted; }
  &__game { font-size: 12px; font-weight: 700; color: $text-secondary; }
  &__symbol { font-size: 13px; font-weight: 700; }

  &__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  &__score   { font-size: 16px; font-weight: 700; }
  &__opponent { font-size: 13px; font-weight: 700; color: $text-primary; }

  &--win  .result-card__score, &--win  .result-card__symbol { color: $result-win; }
  &--draw .result-card__score, &--draw .result-card__symbol { color: $result-draw; }
  &--lose .result-card__score, &--lose .result-card__symbol { color: $result-lose; }
}
</style>

<script define:vars={{ GAS_URL }}>
const sampleArchive = {
  "2024-25": [
    { date: "2025.03.10", cat: "メジャー", game: "春季大会１回戦", score: "5 - 2", opponent: "港南LL", result: "WIN",  type: "公式戦" },
    { date: "2025.02.15", cat: "ジュニア", game: "オープン戦",     score: "3 - 3", opponent: "磯子LL", result: "DRAW", type: "OP戦"  },
  ],
  "2023-24": [
    { date: "2024.08.10", cat: "メジャー", game: "夏季大会決勝",   score: "8 - 1", opponent: "鶴見LL", result: "WIN",  type: "公式戦" },
  ],
};

const catClass     = { "メジャー": "major", "マイナー": "minor", "ジュニア": "junior" };
const resultSymbol = { WIN: "○", DRAW: "△", LOSE: "●" };
const resultClass  = { WIN: "win", DRAW: "draw", LOSE: "lose" };

async function loadArchive() {
  let archive;
  try {
    const res = await fetch(`${GAS_URL}?action=archive`);
    archive = await res.json();
  } catch {
    archive = sampleArchive;
  }

  const list = document.getElementById('archiveList');
  list.innerHTML = Object.entries(archive).map(([season, results]) => `
    <div class="season-block">
      <h2 class="season-block__title">${season}</h2>
      ${results.map(r => `
        <div class="result-card result-card--${resultClass[r.result]}">
          <div class="result-card__left">
            <span class="cat-badge cat-badge--${catClass[r.cat]}">${r.cat}</span>
            <span class="result-card__date">${r.date}</span>
            <span class="result-card__game">${r.game}</span>
          </div>
          <span class="result-card__symbol">${resultSymbol[r.result]}</span>
          <div class="result-card__right">
            <span class="result-card__score">${r.score}</span>
            <span class="result-card__opponent">${r.opponent}</span>
          </div>
        </div>
      `).join('')}
    </div>
  `).join('');
}

loadArchive();
</script>
