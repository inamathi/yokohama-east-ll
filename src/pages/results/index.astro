---
import Layout from "@/layouts/Layout.astro";

const GAS_URL = "https://script.google.com/macros/s/AKfycbzk5a9ycCom5ctNIl02Eu5lvHNi8kMbiMZB-QU_VMXYQE7of6b5eVaF6cF82fggJWPY/exec";
---

<Layout title="試合結果 | 横浜東リトルリーグ">

  <div class="page-title-bar">
    <div class="container">
      <h1>試合結果</h1>
      <p class="sub">RESULTS</p>
    </div>
  </div>

  <div class="results-wrap container">

    <!-- タブ + フィルター -->
    <div class="tab-bar">
      <button class="tab-btn is-active" data-tab="all">すべて</button>
      <button class="tab-btn" data-tab="メジャー">メジャー</button>
      <button class="tab-btn" data-tab="マイナー">マイナー</button>
      <button class="tab-btn" data-tab="ジュニア">ジュニア</button>
      <button class="filter-btn" id="filterBtn" aria-label="絞り込み">
        <span class="filter-icon"></span>
        <span class="filter-label">絞り込み</span>
      </button>
    </div>

    <!-- フィルターパレット -->
    <div class="filter-palette" id="filterPalette" aria-hidden="true">
      <div class="filter-overlay" id="filterOverlay"></div>
      <div class="filter-panel">
        <div class="filter-field">
          <label class="filter-field__label">年度</label>
          <select class="filter-field__select" id="yearSelect">
            <option value="2025-26">2025-26</option>
            <option value="2024-25">2024-25</option>
          </select>
        </div>
        <div class="filter-field">
          <label class="filter-field__label">試合種別</label>
          <div class="filter-radios">
            <label class="filter-radio"><input type="radio" name="gameType" value="all" checked /> すべて</label>
            <label class="filter-radio"><input type="radio" name="gameType" value="公式戦" /> 公式戦のみ</label>
            <label class="filter-radio"><input type="radio" name="gameType" value="OP戦" /> OP戦のみ</label>
          </div>
        </div>
        <button class="filter-ok" id="filterOk">OK</button>
      </div>
    </div>

    <!-- 結果リスト -->
    <div class="results-list" id="resultsList">
      <div class="results-loading">読み込み中…</div>
    </div>

  </div>

</Layout>

<style lang="scss">
@use 'var' as *;

.results-wrap {
  padding-top: 0;
  padding-bottom: 48px;
}

// ── タブバー ──
.tab-bar {
  display: flex;
  align-items: stretch;
  background: $navy-mid;
  border-bottom: 1px solid $border;
  position: relative;
}

.tab-btn {
  flex: 1;
  font-size: 12px;
  font-weight: 700;
  color: $text-muted;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: 12px 4px;
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s;

  @include pc { font-size: 13px; padding: 14px 16px; flex: none; }

  &.is-active {
    color: $text-primary;
    border-bottom-color: $cyan;
  }
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-left: auto;
  padding: 10px 16px;
  background: none;
  border: none;
  border-left: 1px solid $border;
  color: $text-muted;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;

  &:hover { color: $text-primary; }
}

.filter-icon {
  display: flex;
  flex-direction: column;
  gap: 3px;

  &::before, &::after {
    content: '';
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
  }
  &::before { width: 14px; }
  &::after  { width: 8px; }
}

.filter-label { display: none; @include pc { display: block; } }

// ── フィルターパレット ──
.filter-palette {
  position: fixed;
  inset: 0;
  z-index: 200;
  pointer-events: none;

  &.is-open {
    pointer-events: auto;
    .filter-overlay { opacity: 1; }
    .filter-panel { transform: translateY(0); opacity: 1; }
  }
}

.filter-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.5);
  opacity: 0;
  transition: opacity 0.25s;
}

.filter-panel {
  position: absolute;
  top: 60px;
  left: 0;
  right: 0;
  background: #1c2a48;
  padding: 20px $margin-mobile;
  display: flex;
  flex-direction: column;
  gap: 20px;
  transform: translateY(-8px);
  opacity: 0;
  transition: transform 0.25s, opacity 0.25s;
  box-shadow: 0 12px 40px rgba(0,0,0,0.5);

  @include pc {
    top: 72px;
    left: auto;
    right: 64px;
    width: 320px;
    border-radius: 0 0 8px 8px;
  }
}

.filter-field {
  display: flex;
  flex-direction: column;
  gap: 8px;

  &__label {
    font-size: 11px;
    font-weight: 700;
    color: $text-muted;
  }

  &__select {
    background: $navy-dark;
    color: $text-primary;
    border: 1px solid $border;
    border-radius: 6px;
    padding: 10px 12px;
    font-size: 13px;
    font-family: $font-body;
    width: 100%;
  }
}

.filter-radios {
  display: flex;
  gap: 20px;
}

.filter-radio {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: $text-secondary;
  cursor: pointer;

  input { accent-color: $cyan; }
}

.filter-ok {
  background: $cyan;
  color: $navy;
  font-size: 14px;
  font-weight: 700;
  border: none;
  border-radius: 6px;
  padding: 12px;
  cursor: pointer;
  transition: opacity 0.2s;
  margin-top: 4px;

  &:hover { opacity: 0.85; }
}

// ── 結果リスト ──
.results-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 16px;
}

.results-loading {
  font-size: 13px;
  color: $text-muted;
  padding: 24px 0;
  text-align: center;
}

.result-card {
  background: $navy-mid;
  border-radius: 8px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;

  &__left {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-start;
  }

  &__date {
    font-size: 10px;
    color: $text-muted;
  }

  &__game {
    font-size: 12px;
    font-weight: 700;
    color: $text-secondary;
  }

  &__symbol {
    font-size: 13px;
    font-weight: 700;
  }

  &__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  &__score {
    font-size: 16px;
    font-weight: 700;
  }

  &__opponent {
    font-size: 13px;
    font-weight: 700;
    color: $text-primary;
  }

  &--win  .result-card__score, &--win  .result-card__symbol { color: $result-win; }
  &--draw .result-card__score, &--draw .result-card__symbol { color: $result-draw; }
  &--lose .result-card__score, &--lose .result-card__symbol { color: $result-lose; }
}
</style>

<script define:vars={{ GAS_URL }}>
let allResults = [];
let currentTab = 'all';
let currentType = 'all';

// サンプルデータ（GAS未実装の間）
const sampleData = [
  { date: "2026.06.22", cat: "メジャー", game: "全国選抜神奈川連盟大会１回戦", score: "13 - 3", opponent: "湘南連合",   result: "WIN",  type: "公式戦" },
  { date: "2026.06.22", cat: "マイナー", game: "オープン戦",                   score: "4 - 4",  opponent: "港北LL",     result: "DRAW", type: "OP戦"  },
  { date: "2026.06.15", cat: "メジャー", game: "全国選抜神奈川連盟大会２回戦", score: "2 - 5",  opponent: "鶴見LL",     result: "LOSE", type: "公式戦" },
  { date: "2026.06.15", cat: "ジュニア", game: "オープン戦",                   score: "6 - 1",  opponent: "緑区LL",     result: "WIN",  type: "OP戦"  },
  { date: "2026.06.08", cat: "マイナー", game: "春季地区大会",                 score: "3 - 2",  opponent: "保土ヶ谷LL", result: "WIN",  type: "公式戦" },
  { date: "2026.06.08", cat: "メジャー", game: "オープン戦",                   score: "1 - 4",  opponent: "中区LL",     result: "LOSE", type: "OP戦"  },
];

const catClass = { "メジャー": "major", "マイナー": "minor", "ジュニア": "junior" };
const resultSymbol = { WIN: "○", DRAW: "△", LOSE: "●" };
const resultClass  = { WIN: "win", DRAW: "draw", LOSE: "lose" };

function renderResults() {
  const list = document.getElementById('resultsList');
  const filtered = allResults.filter(r => {
    if (currentTab !== 'all' && r.cat !== currentTab) return false;
    if (currentType !== 'all' && r.type !== currentType) return false;
    return true;
  });

  if (filtered.length === 0) {
    list.innerHTML = '<div class="results-loading">該当する試合がありません</div>';
    return;
  }

  list.innerHTML = filtered.map(r => `
    <div class="result-card result-card--${resultClass[r.result]}">
      <div class="result-card__left">
        <span class="cat-badge cat-badge--${catClass[r.cat]}">${r.cat}</span>
        <span class="result-card__date">${r.date}</span>
        <span class="result-card__game">${r.game}</span>
      </div>
      <span class="result-card__symbol">${resultSymbol[r.result]}</span>
      <div class="result-card__right">
        <span class="result-card__score">${r.score}</span>
        <span class="result-card__opponent">${r.opponent}</span>
      </div>
    </div>
  `).join('');
}

async function loadResults() {
  try {
    const res = await fetch(`${GAS_URL}?action=results`);
    const data = await res.json();
    allResults = data.results || sampleData;
  } catch {
    allResults = sampleData;
  }
  renderResults();
}

// タブ切り替え
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');
    currentTab = btn.dataset.tab;
    renderResults();
  });
});

// フィルター
const filterBtn     = document.getElementById('filterBtn');
const filterPalette = document.getElementById('filterPalette');
const filterOverlay = document.getElementById('filterOverlay');
const filterOk      = document.getElementById('filterOk');

function toggleFilter(open) {
  filterPalette.classList.toggle('is-open', open);
  filterPalette.setAttribute('aria-hidden', String(!open));
}

filterBtn?.addEventListener('click', () => toggleFilter(!filterPalette.classList.contains('is-open')));
filterOverlay?.addEventListener('click', () => toggleFilter(false));
filterOk?.addEventListener('click', () => {
  const checked = document.querySelector('input[name="gameType"]:checked');
  currentType = checked?.value || 'all';
  renderResults();
  toggleFilter(false);
});

loadResults();
</script>
