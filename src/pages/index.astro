---
import Layout from "@/layouts/Layout.astro";

const GAS_URL = "https://script.google.com/macros/s/AKfycbzk5a9ycCom5ctNIl02Eu5lvHNi8kMbiMZB-QU_VMXYQE7of6b5eVaF6cF82fggJWPY/exec";

const categories = [
  {
    step: "01",
    label: "JUNIOR",
    title: "ジュニア",
    age: "〜小3の夏",
    concept: "まず、野球を好きになる。",
    desc: "キャッチボールから始め、野球の楽しさを体全体で覚える時期。うまくできなくていい。グラウンドに来るのが楽しみになることが、すべての出発点です。",
  },
  {
    step: "02",
    label: "MINOR",
    title: "マイナー",
    age: "小3の夏〜小5の夏",
    concept: "基礎技術を、着実に身につける。",
    desc: "投げる・打つ・守るの基本を反復練習で固める時期。仲間と競い合いながら、自分の成長を実感できるステージです。",
  },
  {
    step: "03",
    label: "MAJOR",
    title: "メジャー",
    age: "小5の夏〜",
    concept: "野球を深く理解し、中学へつなぐ。",
    desc: "リーグ戦・地区大会を戦いながら、戦術・判断力・チームワークを磨く時期。この経験が中学野球への大きな土台になります。",
  },
];
---

<Layout title="横浜東リトルリーグ">

  <!-- ヒーロー -->
  <section class="hero">
    <div class="hero__left">
      <div class="hero__accent"></div>
      <p class="hero__sub">野球で育つ、仲間と育つ。</p>
      <h1 class="hero__title">横浜東<br />リトルリーグ</h1>
      <p class="hero__desc">神奈川東地区・小学生対象<br />体験参加はいつでも歓迎！</p>
      <a href="/contact" class="btn btn--primary">体験参加のお問い合わせ →</a>
    </div>
    <div class="hero__right">
      <div class="hero__photo-placeholder">キービジュアル写真</div>
    </div>
  </section>

  <!-- 活動予定 -->
  <section class="schedule-section">
    <div class="container">
      <span class="section-label">SCHEDULE</span>
      <h2 class="section-title">直近の活動予定</h2>
      <div class="schedule-grid" id="schedule-grid">
        {["メジャー","マイナー","ジュニア"].map(cat => (
          <div class="schedule-col">
            <div class={`schedule-col__header schedule-col__header--${cat === "メジャー" ? "major" : cat === "マイナー" ? "minor" : "junior"}`}>
              {cat}
            </div>
            <div class="schedule-col__list" data-category={cat}>
              <div class="schedule-loading">読み込み中…</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- リード文 -->
  <section class="lead-section">
    <div class="container">
      <p class="lead-section__text">
        お子さんの「やってみたい」をそのまま連れてきてください。<br />
        体験参加は無料。道具も不要。まず見学だけでも大歓迎です。
      </p>
      <a href="/contact" class="btn btn--primary">体験参加のお問い合わせ →</a>
    </div>
  </section>

  <!-- カテゴリ紹介 -->
  <section class="category-section">
    <div class="container">
      <span class="section-label">CATEGORY</span>
      <h2 class="section-title">リトルリーグのカテゴリを紹介</h2>
      <div class="category-grid">
        {categories.map(cat => (
          <div class="category-card">
            <div class="category-card__photo"></div>
            <div class="category-card__body">
              <div class="category-card__meta">
                <span class="category-card__step">STEP {cat.step}</span>
                <span class="category-card__label">{cat.label}</span>
                <span class="category-card__age">{cat.age}</span>
              </div>
              <p class="category-card__concept">{cat.concept}</p>
              <p class="category-card__desc">{cat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- スポンサー -->
  <section class="sponsor-section">
    <div class="container">
      <span class="section-label">SPONSORS</span>
      <div class="sponsor-grid">
        {[1,2,3].map(() => (
          <div class="sponsor-placeholder"></div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style lang="scss">
@use 'var' as *;

// ── ヒーロー ──
.hero {
  background: $navy-mid;
  display: flex;
  flex-direction: column;

  @include pc {
    flex-direction: row;
    min-height: 56rem;
  }

  &__left {
    padding: 4.8rem $margin-mobile 4.0rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;

    @include pc {
      flex: 0 0 50%;
      padding: 8.0rem $margin-pc;
    }
  }

  &__accent {
    width: 4px;
    height: 6.0rem;
    background: $pink;
    border-radius: 2px;
    margin-bottom: 1.2rem;
  }

  &__sub {
    font-size: $fs-base; // 1.3rem = 13px
    font-weight: 700;
    color: $cyan;
    margin-bottom: 0.8rem;
  }

  &__title {
    font-size: clamp(#{$fs-3xl}, 8vw, 4.8rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 2.0rem;
  }

  &__desc {
    font-size: $fs-md; // 1.5rem = 15px
    color: $text-secondary;
    line-height: 1.8;
    margin-bottom: 3.2rem;
  }

  &__right {
    flex: 1;
    min-height: 24rem;
    background: rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;

    @include pc { min-height: unset; }
  }

  &__photo-placeholder {
    font-size: $fs-md; // 1.5rem = 15px
    color: $text-muted;
  }
}

// ── 活動予定 ──
.schedule-section {
  background: $navy;
  padding: 4.0rem 0;
  border-top: 1px solid $border;
}

.schedule-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.4rem;

  @include pc {
    grid-template-columns: repeat(3, 1fr);
  }
}

.schedule-col {
  &__header {
    font-size: $fs-base; // 1.3rem = 13px
    font-weight: 700;
    padding: 0.6rem 1.2rem;
    margin-bottom: 0.8rem;
    border-left: 3px solid;

    &--major  { border-color: $cat-major-bg;  color: $text-primary; }
    &--minor  { border-color: $cat-minor-bg;  color: $text-primary; }
    &--junior { border-color: $cat-junior-bg; color: $text-primary; }
  }

  &__list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
}

.schedule-item {
  display: flex;
  align-items: baseline;
  gap: 1.2rem;
  padding: 1.0rem 1.2rem;
  border-radius: 4px;
  font-size: $fs-base; // 1.3rem = 13px

  &:nth-child(odd) { background: $navy-mid; }

  &__date {
    font-weight: 700;
    color: $cyan;
    white-space: nowrap;
    font-size: $fs-sm; // 1.1rem = 11px
  }

  &__label { color: $text-secondary; }
}

.schedule-loading {
  font-size: $fs-base; // 1.3rem = 13px
  color: $text-muted;
  padding: 1.0rem 1.2rem;
}

// ── リード文 ──
.lead-section {
  background: $navy-mid;
  padding: 4.0rem 0;
  border-top: 1px solid $border;

  .container {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;

    @include pc {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  &__text {
    font-size: clamp(#{$fs-md}, 2vw, #{$fs-lg}); // 15px〜18px
    font-weight: 700;
    line-height: 1.7;
    color: $text-primary;
  }
}

// ── カテゴリ紹介 ──
.category-section {
  background: $navy;
  padding: 4.8rem 0;
  border-top: 1px solid $border;
}

.category-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.6rem;

  @include pc {
    grid-template-columns: repeat(3, 1fr);
  }
}

.category-card {
  background: $navy-mid;
  border-radius: 8px;
  overflow: hidden;

  &__photo {
    width: 100%;
    aspect-ratio: 16/9;
    background: rgba(255,255,255,0.05);
  }

  &__body {
    padding: 1.6rem;
  }

  &__meta {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    margin-bottom: 1.2rem;
  }

  &__step {
    font-size: 0.9rem; // 9px
    font-weight: 700;
    color: $text-muted;
  }

  &__label {
    font-size: 0.9rem; // 9px
    font-weight: 700;
    color: $text-muted;
  }

  &__age {
    font-size: $fs-sm; // 1.1rem = 11px
    color: $text-muted;
    margin-left: auto;
  }

  &__concept {
    font-size: $fs-md; // 1.5rem = 15px
    font-weight: 700;
    color: $text-primary;
    margin-bottom: 0.8rem;
  }

  &__desc {
    font-size: $fs-base; // 1.3rem = 13px
    color: $text-secondary;
    line-height: 1.75;
  }
}

// ── スポンサー ──
.sponsor-section {
  background: $navy-mid;
  padding: 3.2rem 0;
  border-top: 1px solid $border;
}

.sponsor-grid {
  display: flex;
  gap: 1.6rem;
  flex-wrap: wrap;
  margin-top: 1.6rem;
}

.sponsor-placeholder {
  width: 12.0rem;
  height: 5.6rem;
  background: rgba(255,255,255,0.05);
  border-radius: 4px;
}
</style>

<script define:vars={{ GAS_URL }}>
// 週末スケジュールをGASから取得
async function loadSchedule() {
  try {
    const res = await fetch(`${GAS_URL}?action=schedule`);
    const data = await res.json();

    const categories = ["メジャー", "マイナー", "ジュニア"];
    categories.forEach(cat => {
      const list = document.querySelector(`[data-category="${cat}"]`);
      if (!list) return;

      const items = (data[cat] || []).slice(0, 8);
      if (items.length === 0) {
        list.innerHTML = '<div class="schedule-loading">予定はありません</div>';
        return;
      }

      list.innerHTML = items.map((item) => `
        <div class="schedule-item">
          <span class="schedule-item__date">${item.date}</span>
          <span class="schedule-item__label">${item.label}</span>
        </div>
      `).join("");
    });
  } catch (e) {
    document.querySelectorAll(".schedule-loading").forEach(el => {
      el.textContent = "読み込みできませんでした";
    });
  }
}

loadSchedule();
</script>
